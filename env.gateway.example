# Template para la máquina gateway + frontend.
# Copiar este archivo a .env en la misma carpeta antes de hacer docker compose up.

# ── Seeds del gateway ──────────────────────────────────────────────────────────
#
# Lista de IPs de los servidores, separadas por coma. Puerto siempre 9090 (REST HTTP).
# El gateway intenta conectarse a cada uno al arrancar.
# Si un servidor está caído, lo marca DESCONECTADO y lo reintenta con cada petición.
#
# Ejemplo para 4 máquinas:
GATEWAY_SEEDS=192.168.1.10:9090,192.168.1.11:9090,192.168.1.12:9090,192.168.1.13:9090
