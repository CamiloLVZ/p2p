# Entorno virtual
.venv/
venv/

# Cache de Python
__pycache__/
*.pyc
*.pyo

# Dataset (datos de entrenamiento, no necesarios para servir)
dataset/*
!dataset/.gitkeep

# Archivos temporales
*.tmp
*.log

# Salidas del entrenamiento (checkpoints intermedios, métricas, gráficas)
outputs/checkpoints/*
!outputs/checkpoints/.gitkeep
outputs/metrics/*
!outputs/metrics/.gitkeep
outputs/plots/*
!outputs/plots/.gitkeep

