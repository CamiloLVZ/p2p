# Copiá este archivo a .env y completá los valores para ESTA máquina.
# Cada máquina tiene su propio .env — nunca compartas el mismo archivo entre máquinas.

# Identificador único de este servidor (debe ser distinto en cada máquina)
SERVER_ID=servidor-a

# IP de ESTA máquina que los otros servidores usarán para conectarse.
# Usá la IP de Hamachi, IP pública, o IP de red local según tu setup.
SERVER_HOST=

# Lista de peers conocidos: "id:ip:puerto" separados por coma.
# Ejemplo para dos máquinas:
#   Máquina A: SERVER_PEERS=servidor-b:192.168.1.20:8080
#   Máquina B: SERVER_PEERS=servidor-a:192.168.1.10:8080
SERVER_PEERS=

# Base de datos MySQL (usada dentro del contenedor)
MYSQL_USER=root
MYSQL_PASSWORD=Admin2025
