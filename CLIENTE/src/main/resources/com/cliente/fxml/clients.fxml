<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>
<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.cliente.presentation.controller.ClientsController"
      styleClass="view-root" spacing="20">
    <padding><Insets top="32" right="32" bottom="32" left="32"/></padding>

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="12">
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label text="Gestión de Clientes" styleClass="view-title"/>
            <Label text="Clientes actualmente conectados al servidor."
                   styleClass="view-subtitle"/>
        </VBox>
        <Label fx:id="statusLabel" styleClass="status-label"/>
        <Button fx:id="refreshButton" text="↻  Actualizar"
                onAction="#handleRefresh" styleClass="btn-secondary"/>
    </HBox>

    <!-- Table -->
    <TableView fx:id="clientsTable" VBox.vgrow="ALWAYS" styleClass="data-table">
        <columns>
            <TableColumn fx:id="colId"     text="ID"       prefWidth="130"/>
            <TableColumn fx:id="colName"   text="Nombre"   prefWidth="180"/>
            <TableColumn fx:id="colIp"     text="IP"       prefWidth="160"/>
            <TableColumn fx:id="colPort"   text="Puerto"   prefWidth="80"/>
            <TableColumn fx:id="colStatus" text="Estado"   prefWidth="120"/>
        </columns>
    </TableView>

</VBox>
