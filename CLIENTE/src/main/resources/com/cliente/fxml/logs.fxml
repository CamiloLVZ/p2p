<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>
<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.cliente.presentation.controller.LogsController"
      styleClass="view-root" spacing="20">
    <padding><Insets top="32" right="32" bottom="32" left="32"/></padding>

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="12">
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label text="Logs del Sistema" styleClass="view-title"/>
            <Label text="Registros de actividad técnica del servidor."
                   styleClass="view-subtitle"/>
        </VBox>
        <Label text="SESIÓN ACTIVA" styleClass="badge-active"/>
        <Label fx:id="statusLabel" styleClass="status-label"/>
        <ComboBox fx:id="sourceCombo" promptText="Fuente" prefWidth="200"/>
        <Button fx:id="refreshButton" text="↻  Actualizar"
                onAction="#handleRefresh" styleClass="btn-secondary"/>
        <Button text="⬇  Exportar CSV"
                onAction="#handleExport" styleClass="btn-secondary"/>
    </HBox>

    <!-- Table -->
    <TableView fx:id="logsTable" VBox.vgrow="ALWAYS" styleClass="data-table">
        <columns>
            <TableColumn fx:id="colDate"        text="FECHA"                   prefWidth="130"/>
            <TableColumn fx:id="colTime"        text="HORA"                    prefWidth="110"/>
            <TableColumn fx:id="colDescription" text="DESCRIPCIÓN DEL EVENTO"  prefWidth="600"/>
        </columns>
    </TableView>

</VBox>
