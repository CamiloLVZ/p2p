<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>
<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.cliente.presentation.controller.MessagesController"
      styleClass="view-root" spacing="20">
    <padding><Insets top="32" right="32" bottom="32" left="32"/></padding>

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="12">
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label text="Mensajes Disponibles" styleClass="view-title"/>
            <Label text="Cola de entrada de transacciones y notificaciones del sistema."
                   styleClass="view-subtitle"/>
        </VBox>
        <Label fx:id="statusLabel" styleClass="status-label"/>
        <Button fx:id="refreshButton" text="↻  Actualizar"
                onAction="#handleRefresh" styleClass="btn-secondary"/>
    </HBox>

    <!-- Messages list -->
    <ScrollPane fx:id="scrollPane" VBox.vgrow="ALWAYS"
                styleClass="messages-scroll" fitToWidth="true"
                hbarPolicy="NEVER">
        <VBox fx:id="messagesContainer" spacing="1" styleClass="messages-container"/>
    </ScrollPane>

</VBox>
