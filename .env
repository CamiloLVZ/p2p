# Template para una máquina servidor.
# Copiar este archivo a .env en la misma carpeta antes de hacer docker compose up.
# Cada máquina tiene valores distintos — nunca compartas el mismo .env entre máquinas.

# ── Identidad de este servidor ─────────────────────────────────────────────────

# ID único. Debe coincidir con el nombre que los otros servidores usan como peer.
# Ejemplo: servidor1, servidor2, servidor3, servidor4
SERVER_ID=servidor2

# IP de ESTA máquina que los otros servidores usarán para conectarse (TCP P2P).
# Usá la IP de Hamachi, IP pública, o IP de LAN según tu red.
SERVER_HOST=26.109.149.221

# Lista de los OTROS servidores: "id:ip:puerto" separados por coma.
# Puerto siempre 8080 (TCP P2P).
# Ejemplo para 4 máquinas (completar desde la máquina 1):
SERVER_PEERS=servidor3:26.111.70.213:8080

# ── Base de datos ──────────────────────────────────────────────────────────────

MYSQL_USER=root
MYSQL_PASSWORD=Admin2025
